{
  "name": "icbe",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@gameroman/config": "0.2.2",
      "@tailwindcss/vite": "4.3.2",
      "@types/bun": "1.3.14",
      "astro": "7.0.6",
      "solid-js": "1.9.14",
      "tailwindcss": "4.3.2",
      "wrangler": "4.107.0"
    }
  },
  "scripts": {
    "build:apps": "bun run -F './apps/*' build",
    "build:userscript": "bun run --cwd ./packages/colorproven-userscript build",
    "format": "biome check --write --linter-enabled=false",
    "lint": "biome check",
    "test": "bun test",
    "typegen": "bun run --cwd ./apps/icbe typegen"
  },
  "overrides": {
    "@cloudflare/vite-plugin": "1.43.0",
    "@jridgewell/trace-mapping": "0.3.31",
    "esbuild": "0.28.1",
    "is-docker": "4.0.0",
    "semver": "7.8.5",
    "unstorage": "2.0.0-alpha.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@gameroman/config": "catalog:",
    "typescript": "6.0.3"
  }
}
